flowchart LR

    subgraph IN["Inputs"]
        direction TB
        RS["Remote Sensing\nLandsat/Sentinel NDVI\nLandsat ETf\nSNODAS SWE"]
        MET["Meteorology\nGridMET / ERA5-Land"]
        PROP["Properties\nSoils, LULC,\nIrrigation"]
    end

    subgraph SWIM["SWIM Model"]
        direction TB
        KC["NDVI → Kcb\nsigmoid function"]
        SWB["FAO-56 Dual Kc\nSoil Water Balance"]
        AUX["Snow Melt\nRunoff\nIrrigation\nGW Subsidy"]
        KC --> SWB
        AUX --> SWB
    end

    subgraph CAL["Calibration"]
        direction TB
        OBS["Observed ETf\nat Landsat dates"]
        PEST["PEST++ IES\n200 realizations\n8 params/site"]
    end

    subgraph VAL["Validation"]
        direction TB
        FLUX["Flux Tower ET"]
        OPENET["OpenET\n6 models + ensemble"]
    end

    IN --> SWIM
    SWB -->|"modeled ETf"| PEST
    OBS -->|"target ETf"| PEST
    PEST -.->|"updated params"| SWB
    SWB -->|"calibrated daily ET"| VAL

    classDef inStyle fill:#E8F0FE,stroke:#4C72B0,stroke-width:2px
    classDef swimStyle fill:#E8F5E9,stroke:#55A868,stroke-width:2px
    classDef calStyle fill:#FFF3E0,stroke:#DD8452,stroke-width:2px
    classDef valStyle fill:#FFEBEE,stroke:#C44E52,stroke-width:2px

    class RS,MET,PROP inStyle
    class KC,SWB,AUX swimStyle
    class OBS,PEST calStyle
    class FLUX,OPENET valStyle
